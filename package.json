{
  "name": "vant-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "staging": "vp build --mode staging",
    "prod": "vp build --mode production",
    "preview": "vp preview",
    "build": "vue-tsc -b && vp build",
    "type-check": "vue-tsc -b --force",
    "check": "vp check",
    "lint": "vp lint . --fix",
    "format": "vp fmt src/",
    "test": "vp test --run",
    "test:watch": "vp test",
    "test:coverage": "vp test --run --coverage",
    "prepare": "husky",
    "cz": "cz"
  },
  "dependencies": {
    "@tanstack/vue-query": "5.100.14",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.13.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vant": "^4.9.24",
    "vconsole": "^3.15.1",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@types/node": "^24.10.1",
    "@types/nprogress": "^0.2.3",
    "@unocss/preset-rem-to-px": "66.7.0",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "4.1.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "nprogress": "^0.2.0",
    "postcss-mobile-forever": "5.0.0",
    "terser": "^5.44.1",
    "typescript": "~6.0.3",
    "unocss": "66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.14",
    "vite-plugin-vconsole": "^2.1.1",
    "vite-plus": "0.1.22",
    "vue-tsc": "^3.3.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "vp lint --fix",
      "vp fmt"
    ],
    "*.css": [
      "vp fmt"
    ],
    "*.{json,md}": [
      "vp fmt"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "esbuild"
    ]
  }
}
